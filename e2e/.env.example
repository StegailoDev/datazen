# E2E Test Environment Variables
# Copy this file to e2e/.env and fill in your values.

# PostgreSQL
E2E_PG_HOST=localhost
E2E_PG_PORT=5432
E2E_PG_DB=postgres
E2E_PG_USER=postgres
E2E_PG_PASSWORD=
E2E_PG_SUPER=postgres

# PostgreSQL read-only user (for permission tests)
E2E_PG_RO_USER=datazen_readonly
E2E_PG_RO_PASSWORD=changeme

# MySQL
E2E_MYSQL_HOST=127.0.0.1
E2E_MYSQL_PORT=3306
E2E_MYSQL_DB=datazen_test
E2E_MYSQL_USER=root
E2E_MYSQL_PASSWORD=
E2E_MYSQL_RO_USER=datazen_readonly
E2E_MYSQL_RO_PASSWORD=changeme

# Redis
E2E_REDIS_HOST=127.0.0.1
E2E_REDIS_PORT=6379
E2E_REDIS_PASSWORD=

# Kiwi (HTTP-proxied SQL service)
E2E_KIWI_URL=https://kiwi.akusre.com
E2E_KIWI_TOKEN=
E2E_KIWI_USERNAME=
E2E_KIWI_DOMAIN=
E2E_KIWI_SOURCE_TYPE=4
