#!/usr/bin/env bash
# Pre-commit hook: block commits containing passwords or sensitive patterns.
# Scans only staged files (not the full repo).

set -euo pipefail

PATTERNS=(
  # Real credentials that leaked previously
  'REDACTED_PG_PASSWORD'
  'REDACTED_RO_PASSWORD'
  'REDACTED_REDIS_PASSWORD'
  # Generic secret patterns (value side of assignments)
  'PRIVATE.KEY'
  'BEGIN RSA'
  'BEGIN OPENSSH'
  # AWS / cloud keys
  'AKIA[0-9A-Z]{16}'
  'sk_live_'
  'ghp_[0-9a-zA-Z]{36}'
  'gho_[0-9a-zA-Z]{36}'
)

ALLOW_LIST=(
  '.env.example'
  'pre-commit'
  '.gitignore'
  'CHANGELOG'
  '*.md'
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

EXIT_CODE=0

for pattern in "${PATTERNS[@]}"; do
  while IFS= read -r file; do
    [ -z "$file" ] && continue

    skip=false
    for allow in "${ALLOW_LIST[@]}"; do
      case "$file" in
        $allow) skip=true; break ;;
      esac
    done
    $skip && continue

    if git diff --cached -- "$file" | grep -qiE "$pattern"; then
      echo "ERROR: Sensitive pattern '$pattern' found in staged file: $file"
      EXIT_CODE=1
    fi
  done <<< "$STAGED_FILES"
done

if [ $EXIT_CODE -ne 0 ]; then
  echo ""
  echo "Commit blocked: sensitive data detected in staged changes."
  echo "If this is a false positive, use: git commit --no-verify"
  exit 1
fi

exit 0
