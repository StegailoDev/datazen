{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DataZen",
  "version": "0.1.0",
  "identifier": "com.tbeasy.datazen",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DataZen",
        "width": 680,
        "height": 480,
        "minWidth": 520,
        "minHeight": 400,
        "decorations": false,
        "backgroundColor": "#0f172a"
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
